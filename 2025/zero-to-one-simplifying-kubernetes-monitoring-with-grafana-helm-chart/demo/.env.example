# Grafana Cloud Metrics Configuration
GRAFANA_CLOUD_METRICS_USERNAME=your-metrics-username
GRAFANA_CLOUD_METRICS_PASSWORD=your-metrics-password

# Grafana Cloud Logs Configuration
GRAFANA_CLOUD_LOGS_USERNAME=your-logs-username
GRAFANA_CLOUD_LOGS_PASSWORD=your-logs-password

# Grafana Cloud OTLP Configuration
GRAFANA_CLOUD_OTLP_USERNAME=your-otlp-username
GRAFANA_CLOUD_OTLP_PASSWORD=your-otlp-password

# Grafana Cloud Profiles Configuration
GRAFANA_CLOUD_PROFILES_USERNAME=your-profiles-username
GRAFANA_CLOUD_PROFILES_PASSWORD=your-profiles-password

# Grafana Cloud Remote Config Configuration
GRAFANA_CLOUD_REMOTE_CONFIG_USERNAME=your-remote-config-username
GRAFANA_CLOUD_REMOTE_CONFIG_PASSWORD=your-remote-config-password